{{- $sections := slice "espresso" "fehleranalyse" "bohnen" "equipment" "milch" "bruehmethoden" "grundlagen" -}}
{{- $pages := where .Site.RegularPages "Section" "in" $sections -}}
[
  {{- range $i, $p := $pages -}}
  {{- if $i }},{{ end }}
  {
    "title":       {{ $p.Title | jsonify }},
    "description": {{ $p.Description | jsonify }},
    "url":         {{ $p.RelPermalink | jsonify }},
    "tags":        {{ $p.Params.tags | jsonify }},
    "categories":  {{ $p.Params.categories | jsonify }},
    "difficulty":  {{ $p.Params.difficulty | jsonify }}
  }
  {{- end }}
]
